    "insights.vm.learnings.adjacent.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The main story is clear enough to act on, but adjacent sleep, recovery, training or nutrition patterns need more overlap before they become separate discoveries."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Главная история достаточно ясна для действий, но смежным паттернам сна, восстановления, тренировок или питания нужно больше пересечения, прежде чем они станут отдельными открытиями."
          }
        }
      }
    },
