    "support.faq.item01.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WeekFit is your personal training and recovery coach. It helps you plan workouts, meals, hydration, sleep, and routines in one place, while guiding you throughout the day using your activity, recovery, and health data."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WeekFit — ваш персональный помощник для тренировок и восстановления. Он помогает планировать тренировки, питание, воду, сон и рутины в одном месте и подсказывает, что важно в течение дня."
          }
        }
      }
    },
    "support.faq.item01.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What is WeekFit?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Что такое WeekFit?"
          }
        }
      }
    },
    "support.faq.item02.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Plan helps you organize your upcoming week ahead. Today reacts to what is actually happening during the day. Coach then adapts suggestions based on your activity, recovery, meals, hydration, sleep, and timing."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Plan помогает заранее организовать неделю. Today реагирует на то, что реально происходит в течение дня. Coach адаптирует советы с учетом активности, восстановления, питания, воды, сна и времени."
          }
        }
      }
    },
    "support.faq.item02.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "How does WeekFit work day to day?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Как WeekFit работает каждый день?"
          }
        }
      }
    },
    "support.faq.item03.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Today focuses on your current day, metrics, and live activity. Plan is where you organize workouts, meals, recovery, sleep, and routines ahead of time."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Today показывает текущий день, метрики и живую активность. Plan нужен, чтобы заранее организовать тренировки, питание, восстановление, сон и рутины."
          }
        }
      }
    },
    "support.faq.item03.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What is the difference between Today and Plan?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Чем отличаются Today и Plan?"
          }
        }
      }
    },
    "support.faq.item04.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Plan helps you organize things ahead of time. Logging is for things that already happened during the day — like meals, coffee, water, workouts, recovery, or sleep routines."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Plan помогает заранее организовать дела. Логирование — для того, что уже произошло в течение дня: еды, кофе, воды, тренировок, восстановления или рутин сна."
          }
        }
      }
    },
    "support.faq.item04.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What is the difference between planning and logging?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Чем отличаются планирование и логирование?"
          }
        }
      }
    },
    "support.faq.item05.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WeekFit shows data that already exists in Apple Health. Check Health permissions and make sure Apple Health has data for the selected day."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WeekFit показывает данные, которые уже есть в Apple Health. Проверьте разрешения Health и убедитесь, что в Apple Health есть данные за выбранный день."
          }
        }
      }
    },
    "support.faq.item05.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Why are my metrics empty?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Почему мои метрики пустые?"
          }
        }
      }
    },
    "support.faq.item06.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No. You can use WeekFit without Apple Watch. But sleep, workouts, recovery, and activity data may be missing or less accurate, which can affect coaching insights and recommendations."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Нет. WeekFit можно использовать без Apple Watch. Но данные сна, тренировок, восстановления и активности могут отсутствовать или быть менее точными, что влияет на инсайты Coach."
          }
        }
      }
    },
    "support.faq.item06.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Do I need an Apple Watch?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Нужен ли Apple Watch?"
          }
        }
      }
    },
    "support.faq.item07.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Daily Status gives a simple overview of your activity, nutrition, recovery, sleep, hydration, and Apple Health data throughout the day."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Daily Status дает простой обзор активности, питания, восстановления, сна, гидратации и данных Apple Health в течение дня."
          }
        }
      }
    },
    "support.faq.item07.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What is Daily Status?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Что такое Daily Status?"
          }
        }
      }
    },
    "support.faq.item08.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The percentages help you understand balance during the day. They are not meant to be perfect scores or goals to chase."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Проценты помогают понимать баланс дня. Это не идеальные оценки и не цели, за которыми нужно гнаться."
          }
        }
      }
    },
    "support.faq.item08.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What do the percentages mean?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Что означают проценты?"
          }
        }
      }
    },
    "support.faq.item09.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Activity can go above 100% when your movement, workouts, exercise minutes, or daily activity go beyond your current activity goal."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Activity может превышать 100%, когда движение, тренировки, минуты упражнений или дневная активность превышают текущую цель активности."
          }
        }
      }
    },
    "support.faq.item09.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Why can Activity go above 100%?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Почему Activity может быть выше 100%?"
          }
        }
      }
    },
    "support.faq.item10.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WeekFit looks at your workouts, movement, recovery, body data, meals, and Apple Health information to build personalized Activity and Nutrition targets. As your day changes, targets can also adjust to better reflect your current energy and recovery needs."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WeekFit учитывает тренировки, движение, восстановление, данные тела, питание и Apple Health, чтобы строить персональные цели Activity и Nutrition. Когда день меняется, цели могут обновляться."
          }
        }
      }
    },
    "support.faq.item10.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "How are your Activity and Nutrition targets calculated?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Как рассчитываются цели Activity и Nutrition?"
          }
        }
      }
    },
    "support.faq.item11.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BMR (Basal Metabolic Rate) is your estimated base energy need — the calories your body uses at rest."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BMR (базальный обмен) — это примерная базовая потребность в энергии: калории, которые тело тратит в покое."
          }
        }
      }
    },
    "support.faq.item11.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What is BMR?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Что такое BMR?"
          }
        }
      }
    },
    "support.faq.item12.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TDEE (Total Daily Energy Expenditure) combines your base metabolism with movement, workouts, and daily activity to estimate your daily energy needs."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TDEE (общий дневной расход энергии) объединяет базовый обмен, движение, тренировки и дневную активность, чтобы оценить дневную потребность в энергии."
          }
        }
      }
    },
    "support.faq.item12.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What is TDEE?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Что такое TDEE?"
          }
        }
      }
    },
    "support.faq.item13.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WeekFit starts with your estimated BMR, then builds a dynamic TDEE using workouts, movement, active calories, recovery, and daily activity. Calories, protein, carbs, fats, and water targets then adapt based on your selected goal."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WeekFit начинает с примерного BMR, затем строит динамический TDEE с учетом тренировок, движения, активных калорий, восстановления и дневной активности. Калории, белки, углеводы, жиры и вода адаптируются к контексту."
          }
        }
      }
    },
    "support.faq.item13.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "How are Nutrition targets calculated?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Как рассчитываются цели Nutrition?"
          }
        }
      }
    },
    "support.faq.item14.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WeekFit roughly follows:\\n\\nBMR + Activity + Workouts = Daily Energy Need\\n\\nYour selected goal then adjusts calories, protein, carbs, fats, and hydration targets."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WeekFit примерно следует формуле:\n\nBMR + Activity + Workouts = дневная потребность в энергии\n\nВыбранная цель затем корректирует калории, белки, углеводы, жиры и воду."
          }
        }
      }
    },
    "support.faq.item14.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "How does WeekFit estimate calories?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Как WeekFit оценивает калории?"
          }
        }
      }
    },
    "support.faq.item15.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Protein is mainly based on body weight and your selected goal. Fats use a percentage of your calorie target. Carbs are calculated from the remaining calories after protein and fats."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Белок в основном зависит от веса тела и выбранной цели. Жиры берутся как доля от цели калорий. Углеводы рассчитываются из оставшихся калорий после белков и жиров."
          }
        }
      }
    },
    "support.faq.item15.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "How are protein, carbs, and fats calculated?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Как рассчитываются белки, углеводы и жиры?"
          }
        }
      }
    },
    "support.faq.item16.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Water target is based mainly on body weight, with extra hydration added when your activity and active calories are higher."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Цель воды в основном зависит от веса тела. Дополнительная гидратация добавляется, когда активность и активные калории выше."
          }
        }
      }
    },
    "support.faq.item16.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "How is water target calculated?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Как рассчитывается цель воды?"
          }
        }
      }
    },
    "support.faq.item17.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WeekFit uses adaptive targets that react to workouts, movement, recovery, meals, and newly available Apple Health data throughout the day."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WeekFit использует адаптивные цели, которые реагируют на тренировки, движение, восстановление, питание и новые данные Apple Health в течение дня."
          }
        }
      }
    },
    "support.faq.item17.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Why do targets change during the day?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Почему цели меняются в течение дня?"
          }
        }
      }
    },
    "support.faq.item18.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WeekFit uses time-adaptive targets during the day. Morning targets are intentionally lighter so progress reflects where your day realistically is instead of expecting full-day nutrition too early."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WeekFit использует цели, адаптированные ко времени дня. Утренние цели специально легче, чтобы прогресс отражал реальное состояние дня, а не требовал полного дневного объема сразу."
          }
        }
      }
    },
    "support.faq.item18.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Why does Nutrition progress feel different in the morning?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Почему прогресс Nutrition утром ощущается иначе?"
          }
        }
      }
    },
    "support.faq.item19.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WeekFit uses ingredients, portions, and meal combinations to estimate calories, protein, carbs, and fats for your meals. While values can vary depending on how meals are built, the goal is to help you clearly understand your overall nutrition, energy balance, and meal composition throughout the day."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WeekFit использует ингредиенты, порции и состав блюд для оценки калорий, белков, углеводов и жиров. Значения могут отличаться в зависимости от продуктов и порций, поэтому это ориентир, а не лабораторная точность."
          }
        }
      }
    },
    "support.faq.item19.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Are nutrition values exact?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Значения питания точные?"
          }
        }
      }
    },
    "support.faq.item20.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Left shows a rough estimate of remaining calories based on your current activity, workouts, and logged meals."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Left показывает примерную оценку оставшихся калорий с учетом текущей активности, тренировок и записанных приемов пищи."
          }
        }
      }
    },
    "support.faq.item20.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What does Left mean in Nutrition?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Что означает Left в Nutrition?"
          }
        }
      }
    },
    "support.faq.item21.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "P stands for protein, C for carbs, and F for fats."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "P означает белки, C — углеводы, F — жиры."
          }
        }
      }
    },
    "support.faq.item21.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What are P, C, and F?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Что такое P, C и F?"
          }
        }
      }
    },
    "support.faq.item22.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Meals lets you create your own dishes, combine ingredients, and plan nutrition around workouts, recovery, and daily routines. WeekFit gives estimates for calories, protein, carbs, and fats to help you stay aware of your nutrition without making tracking feel overwhelming."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Meals позволяет создавать собственные блюда, комбинировать ингредиенты и планировать питание вокруг тренировок, восстановления и рутины. WeekFit дает оценки калорий и макроэлементов."
          }
        }
      }
    },
    "support.faq.item22.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What can I do in Meals?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Что можно делать в Meals?"
          }
        }
      }
    },
    "support.faq.item23.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nutrition appears after you log a meal or add it in Planner and confirm it as completed. If nothing was logged or confirmed, the values stay at zero."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nutrition появляется после того, как вы записали еду или добавили ее в Planner и подтвердили выполнение. Если ничего не записано и не подтверждено, значения остаются нулевыми."
          }
        }
      }
    },
    "support.faq.item23.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Why does nutrition show zero?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Почему питание показывает ноль?"
          }
        }
      }
    },
    "support.faq.item24.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Not necessarily. WeekFit focuses more on balance, recovery, consistency, and awareness than hitting perfect numbers every day."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Не обязательно. WeekFit больше фокусируется на балансе, восстановлении, последовательности и осознанности, а не на идеальных числах каждый день."
          }
        }
      }
    },
    "support.faq.item24.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Should I always hit my calorie target?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Нужно ли всегда попадать в цель калорий?"
          }
        }
      }
    },
    "support.faq.item25.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Workouts and activity can increase your estimated energy needs, which may affect activity progress, recovery, and nutrition targets."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Тренировки и активность могут увеличить примерную потребность в энергии, что влияет на прогресс активности, восстановление и цели питания."
          }
        }
      }
    },
    "support.faq.item25.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Why can targets change after a workout?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Почему цели меняются после тренировки?"
          }
        }
      }
    },
    "support.faq.item26.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Completed Apple Health workouts can be imported into Plan automatically. WeekFit uses them to help keep your day accurate."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Завершенные тренировки из Apple Health могут автоматически импортироваться в Plan. WeekFit использует их, чтобы день оставался точным."
          }
        }
      }
    },
    "support.faq.item26.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Why did my workout appear in Plan?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Почему тренировка появилась в Plan?"
          }
        }
      }
    },
    "support.faq.item27.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Synced means the activity came from Apple Health or Apple Watch and was automatically added to your plan."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Synced означает, что активность пришла из Apple Health или Apple Watch и была автоматически добавлена в план."
          }
        }
      }
    },
    "support.faq.item27.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What does Synced mean?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Что означает Synced?"
          }
        }
      }
    },
    "support.faq.item28.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Upcoming is later today. Live is happening now. Pending means the planned time already passed. Done means you completed it in WeekFit. Synced means it came from Apple Health."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Upcoming — позже сегодня. Live — происходит сейчас. Pending — запланированное время уже прошло. Done — выполнено в WeekFit. Synced — импортировано из Apple Health."
          }
        }
      }
    },
    "support.faq.item28.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What do the Plan statuses mean?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Что означают статусы Plan?"
          }
        }
      }
    },
    "support.faq.item29.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Live means the activity is currently happening based on the planned time or synced workout timing."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Live означает, что активность сейчас идет по запланированному времени или времени синхронизированной тренировки."
          }
        }
      }
    },
    "support.faq.item29.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What does Live mean in Plan?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Что означает Live в Plan?"
          }
        }
      }
    },
    "support.faq.item30.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pending means the planned activity time already passed, but the activity was not completed or synced yet."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pending означает, что время запланированной активности уже прошло, но она еще не выполнена и не синхронизирована."
          }
        }
      }
    },
    "support.faq.item30.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What does Pending mean?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Что означает Pending?"
          }
        }
      }
    },
    "support.faq.item31.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Open Plan, tap plus, choose the activity, and save it. If the activity already happened, you can mark it completed or let Apple Health sync it automatically."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Откройте Plan, нажмите плюс, выберите активность и сохраните ее. Если активность уже была, отметьте ее выполненной или позвольте Apple Health синхронизировать ее автоматически."
          }
        }
      }
    },
    "support.faq.item31.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "How do I log an activity?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Как записать активность?"
          }
        }
      }
    },
    "support.faq.item32.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Start with workouts, then add recovery, meals, hydration, and sleep routines around them. Keep the plan realistic and sustainable."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Начните с тренировок, затем добавьте вокруг них восстановление, питание, воду и рутины сна. Держите план реалистичным и устойчивым."
          }
        }
      }
    },
    "support.faq.item32.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "How should I plan my week?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Как планировать неделю?"
          }
        }
      }
    },
    "support.faq.item33.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yes. You can simply log meals, water, workouts, recovery, or routines during the day and let Coach react to your activity."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Да. Можно просто записывать еду, воду, тренировки, восстановление или рутины в течение дня, а Coach будет реагировать на вашу активность."
          }
        }
      }
    },
    "support.faq.item33.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Can I use WeekFit without planning?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Можно ли использовать WeekFit без планирования?"
          }
        }
      }
    },
    "support.faq.item34.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yes. Apple Health and synced workouts can still provide activity and recovery data, but logging helps Coach understand your day more accurately."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Да. Apple Health и синхронизированные тренировки все равно могут давать данные активности и восстановления, но логирование помогает Coach точнее понимать день."
          }
        }
      }
    },
    "support.faq.item34.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Can I use WeekFit without logging?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Можно ли использовать WeekFit без логирования?"
          }
        }
      }
    },
    "support.faq.item35.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Coach adapts throughout the day based on your activity, recovery, sleep, hydration, meals, and routines. Suggestions may change as your day changes."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Coach адаптируется в течение дня на основе активности, восстановления, сна, гидратации, питания и рутин. Советы могут меняться по мере изменения дня."
          }
        }
      }
    },
    "support.faq.item35.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "How does Coach work?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Как работает Coach?"
          }
        }
      }
    },
    "support.faq.item36.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Coach looks at your activity, hydration, recovery, timing, and routines. After light movement or recovery activities, it may suggest simple actions like hydration or rest."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Coach смотрит на активность, воду, восстановление, время и рутины. После легкого движения или восстановления он может предложить простые действия вроде воды или отдыха."
          }
        }
      }
    },
    "support.faq.item36.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Why does Coach suggest water or tea?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Почему Coach предлагает воду или чай?"
          }
        }
      }
    },
    "support.faq.item37.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Workouts, meals, hydration, sleep, recovery, routines, and synced Apple Health data can all affect Coach suggestions throughout the day."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Тренировки, питание, вода, сон, восстановление, рутины и синхронизированные данные Apple Health могут влиять на подсказки Coach в течение дня."
          }
        }
      }
    },
    "support.faq.item37.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Why do recommendations change during the day?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Почему рекомендации меняются в течение дня?"
          }
        }
      }
    },
    "support.faq.item38.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sleep usually appears only when Apple Health has sleep data available. On iPhone, Sleep Focus or another sleep tracker may be needed."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сон обычно появляется только тогда, когда в Apple Health есть данные сна. На iPhone может понадобиться Фокус сна или другой трекер сна."
          }
        }
      }
    },
    "support.faq.item38.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Why is sleep data missing?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Почему нет данных сна?"
          }
        }
      }
    },
    "support.faq.item39.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HRV stands for heart rate variability. WeekFit uses it as one of several recovery signals from Apple Health."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HRV — вариабельность сердечного ритма. WeekFit использует ее как один из сигналов восстановления из Apple Health."
          }
        }
      }
    },
    "support.faq.item39.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What is HRV?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Что такое HRV?"
          }
        }
      }
    },
    "support.faq.item40.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "RHR stands for resting heart rate. Lower resting heart rate can sometimes reflect better recovery or lower stress."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "RHR — пульс в покое. Более низкий пульс в покое иногда может отражать лучшее восстановление или меньший стресс."
          }
        }
      }
    },
    "support.faq.item40.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What is RHR?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Что такое RHR?"
          }
        }
      }
    },
    "support.faq.item41.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recovery reacts to sleep, workouts, stress, hydration, recovery activities, and overall daily load."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recovery реагирует на сон, тренировки, стресс, гидратацию, восстановительные активности и общую дневную нагрузку."
          }
        }
      }
    },
    "support.faq.item41.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Why can Recovery change during the day?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Почему Recovery меняется в течение дня?"
          }
        }
      }
    },
    "support.faq.item42.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Check notification permissions in iPhone Settings and make sure reminders are turned on inside WeekFit."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Проверьте разрешения уведомлений в настройках iPhone и убедитесь, что напоминания включены внутри WeekFit."
          }
        }
      }
    },
    "support.faq.item42.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Why am I not getting reminders?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Почему я не получаю напоминания?"
          }
        }
      }
    },
    "support.faq.item43.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yes. You can review, change, or remove Apple Health permissions anytime in Apple Health or iPhone Settings."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Да. Вы можете просмотреть, изменить или удалить разрешения Apple Health в любое время в Apple Health или настройках iPhone."
          }
        }
      }
    },
    "support.faq.item43.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Can I change Health permissions?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Можно ли изменить разрешения Health?"
          }
        }
      }
    },
    "support.faq.subtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Answers to the questions you may have while using WeekFit."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ответы на вопросы, которые могут возникнуть при использовании WeekFit."
          }
        }
      }
    },
    "support.faq.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "FAQ"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "FAQ"
          }
        }
      }
    },
    "support.guides.item01.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "First, connect Apple Health and allow the data WeekFit needs. Activity, sleep, workouts, heart data, hydration, and body metrics help the app understand your day better."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сначала подключите Apple Health и разрешите данные, нужные WeekFit. Активность, сон, тренировки, пульс, вода и параметры тела помогают приложению лучше понимать ваш день."
          }
        }
      }
    },
    "support.guides.item01.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Start with Apple Health"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Начните с Apple Health"
          }
        }
      }
    },
    "support.guides.item02.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Today is your live dashboard. Start there to see your current activity, nutrition, recovery, hydration, sleep, and coaching status."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Today — ваш живой дашборд. Начните с него, чтобы увидеть текущую активность, питание, восстановление, воду, сон и статус Coach."
          }
        }
      }
    },
    "support.guides.item02.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Check Today first"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сначала смотрите Today"
          }
        }
      }
    },
    "support.guides.item03.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Daily Status gives a quick view of how your day is going. Look at Activity, Nutrition, and Recovery to understand whether the day is balanced, light, or already demanding."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Daily Status быстро показывает, как идет день. Посмотрите Activity, Nutrition и Recovery, чтобы понять, день сбалансированный, легкий или уже требовательный."
          }
        }
      }
    },
    "support.guides.item03.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Read Daily Status"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Читайте Daily Status"
          }
        }
      }
    },
    "support.guides.item04.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Activity shows how much you have moved compared to your current goal. Walks, workouts, exercise minutes, and Apple Watch activity can all move this number."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Activity показывает, сколько вы двигались относительно текущей цели. Прогулки, тренировки, минуты упражнений и активность Apple Watch могут менять это число."
          }
        }
      }
    },
    "support.guides.item04.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Understand Activity"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Понимайте Activity"
          }
        }
      }
    },
    "support.guides.item05.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nutrition shows your food progress for the day. It uses meals you log or complete and gives a high-level view of calories, protein, carbs, and fats."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nutrition показывает прогресс питания за день. Он использует записанные или выполненные приемы пищи и дает общий взгляд на калории, белки, углеводы и жиры."
          }
        }
      }
    },
    "support.guides.item05.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Understand Nutrition"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Понимайте Nutrition"
          }
        }
      }
    },
    "support.guides.item06.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recovery helps you see whether your body may need an easier day. Sleep, recent workouts, daily load, HRV, resting heart rate, and recovery routines can all affect it."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recovery помогает понять, нужен ли телу более легкий день. На него влияют сон, последние тренировки, дневная нагрузка, HRV, пульс в покое и восстановительные рутины."
          }
        }
      }
    },
    "support.guides.item06.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Understand Recovery"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Понимайте Recovery"
          }
        }
      }
    },
    "support.guides.item07.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Coach looks at what is happening now and suggests what may help next — before training, during activity, after workouts, after sauna, or when recovery looks pressured."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Coach смотрит на то, что происходит сейчас, и предлагает следующий полезный шаг — до тренировки, во время активности, после тренировки, после сауны или когда восстановление под давлением."
          }
        }
      }
    },
    "support.guides.item07.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Use Coach as your next step"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Используйте Coach как следующий шаг"
          }
        }
      }
    },
    "support.guides.item08.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Plan is for organizing your day or week ahead. Add workouts, meals, hydration, recovery, sleep, and routines before they happen."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Plan нужен, чтобы заранее организовать день или неделю. Добавляйте тренировки, приемы пищи, воду, восстановление, сон и рутины до того, как они произойдут."
          }
        }
      }
    },
    "support.guides.item08.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Use Plan for what comes next"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Используйте Plan для того, что впереди"
          }
        }
      }
    },
    "support.guides.item09.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Add the workouts you actually want to do, then leave space for recovery, meals, water, and sleep."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Добавьте тренировки, которые действительно хотите сделать, и оставьте место для восстановления, питания, воды и сна."
          }
        }
      }
    },
    "support.guides.item09.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Plan a realistic week"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Планируйте реалистичную неделю"
          }
        }
      }
    },
    "support.guides.item10.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Plan shows what is coming, what is happening now, and what was already completed, missed, or synced from Apple Health."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Plan показывает, что впереди, что происходит сейчас и что уже выполнено, пропущено или синхронизировано из Apple Health."
          }
        }
      }
    },
    "support.guides.item10.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Use Plan as your day map"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Используйте Plan как карту дня"
          }
        }
      }
    },
    "support.guides.item11.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Upcoming means later today. Live means happening now. Pending means the planned time passed. Done means completed in WeekFit. Synced means imported from Apple Health."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Upcoming — позже сегодня. Live — происходит сейчас. Pending — время прошло. Done — выполнено в WeekFit. Synced — импортировано из Apple Health."
          }
        }
      }
    },
    "support.guides.item11.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Know the Plan statuses"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Знайте статусы Plan"
          }
        }
      }
    },
    "support.guides.item12.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Logging is for real things that happened during the day — coffee, water, meals, workouts, recovery, sauna, breathing, stretching, or sleep routines."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Логирование — для реальных событий дня: кофе, воды, еды, тренировок, восстановления, сауны, дыхания, растяжки или рутин сна."
          }
        }
      }
    },
    "support.guides.item12.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Log what already happened"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Записывайте то, что уже произошло"
          }
        }
      }
    },
    "support.guides.item13.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Use Plan when something is ahead of you. Use logging when something already happened. Both help Coach understand your day better."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Используйте Plan, когда событие впереди. Используйте логирование, когда оно уже произошло. Оба варианта помогают Coach лучше понимать день."
          }
        }
      }
    },
    "support.guides.item13.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Plan before, log after"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Планируйте до, логируйте после"
          }
        }
      }
    },
    "support.guides.item14.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Build your own meals, combine ingredients, and plan nutrition throughout the day. WeekFit helps connect meals with training, recovery, hydration, and energy needs."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Собирайте собственные блюда, комбинируйте ингредиенты и планируйте питание в течение дня. WeekFit помогает связать еду с тренировками, восстановлением, водой и энергией."
          }
        }
      }
    },
    "support.guides.item14.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Create meals from ingredients"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Создавайте блюда из ингредиентов"
          }
        }
      }
    },
    "support.guides.item15.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Meals gives you a high-level view of calories, protein, carbs, and fats based on ingredients and portions. It helps you understand meal balance without making food tracking too complicated."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Meals дает общий взгляд на калории, белки, углеводы и жиры по ингредиентам и порциям. Это помогает понимать баланс блюда без слишком сложного трекинга еды."
          }
        }
      }
    },
    "support.guides.item15.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Use Meals for rough nutrition awareness"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Используйте Meals для общего понимания питания"
          }
        }
      }
    },
    "support.guides.item16.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Use meals and snacks to support your day. Before training, you may want lighter fuel. After training, meals can help recovery and energy balance."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Используйте блюда и перекусы, чтобы поддержать день. Перед тренировкой может подойти легкое топливо. После тренировки еда помогает восстановлению и энергетическому балансу."
          }
        }
      }
    },
    "support.guides.item16.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Plan nutrition around workouts"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Планируйте питание вокруг тренировок"
          }
        }
      }
    },
    "support.guides.item17.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Water, tea, coffee, meals, stretching, sauna, breathing, and sleep routines all help Coach understand your day better."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вода, чай, кофе, еда, растяжка, сауна, дыхание и рутины сна помогают Coach лучше понимать ваш день."
          }
        }
      }
    },
    "support.guides.item17.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Log simple things too"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Записывайте простые вещи тоже"
          }
        }
      }
    },
    "support.guides.item18.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If you use Apple Watch or another app that writes workouts to Apple Health, WeekFit can add completed workouts to your plan."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Если вы используете Apple Watch или другое приложение, которое записывает тренировки в Apple Health, WeekFit может добавить завершенные тренировки в ваш план."
          }
        }
      }
    },
    "support.guides.item18.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Let workouts sync"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Позвольте тренировкам синхронизироваться"
          }
        }
      }
    },
    "support.guides.item19.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WeekFit works without Apple Watch, but workouts, sleep, activity, recovery, HRV, and resting heart rate are usually better when Apple Watch or another tracker writes data to Apple Health."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WeekFit работает без Apple Watch, но тренировки, сон, активность, восстановление, HRV и пульс в покое обычно лучше, когда Apple Watch или другой трекер записывает данные."
          }
        }
      }
    },
    "support.guides.item19.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Use Apple Watch if you have one"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Используйте Apple Watch, если он есть"
          }
        }
      }
    },
    "support.guides.item20.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recovery matters as much as training. Try not to stack too many hard sessions without an easier day."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Восстановление так же важно, как тренировки. Старайтесь не ставить слишком много тяжелых сессий подряд без более легкого дня."
          }
        }
      }
    },
    "support.guides.item20.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Balance hard and easy days"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Балансируйте тяжелые и легкие дни"
          }
        }
      }
    },
    "support.guides.item21.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Breathing, stretching, mobility, walking, sauna, and sleep routines can all help WeekFit understand recovery and daily load."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Дыхание, растяжка, мобилити, ходьба, сауна и рутины сна помогают WeekFit понимать восстановление и дневную нагрузку."
          }
        }
      }
    },
    "support.guides.item21.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Use recovery routines"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Используйте восстановительные рутины"
          }
        }
      }
    },
    "support.guides.item22.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Simple reminders can help you follow the plan during busy days."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Простые напоминания помогают следовать плану в занятые дни."
          }
        }
      }
    },
    "support.guides.item22.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Use reminders if you need them"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Используйте напоминания, если они нужны"
          }
        }
      }
    },
    "support.guides.item23.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your week matters more than one perfect day. Use trends to adjust the next week."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Важнее вся неделя, а не один идеальный день. Используйте тренды, чтобы скорректировать следующую неделю."
          }
        }
      }
    },
    "support.guides.item23.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Look for patterns"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ищите закономерности"
          }
        }
      }
    },
    "support.guides.item24.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Percentages and targets are there to guide awareness, not to create pressure. Some days will be higher, lower, easier, or more demanding."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Проценты и цели нужны для осознанности, а не для давления. Некоторые дни будут выше, ниже, легче или тяжелее."
          }
        }
      }
    },
    "support.guides.item24.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Do not chase perfect numbers"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Не гонитесь за идеальными числами"
          }
        }
      }
    },
    "support.guides.item25.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "For the first few days, connect Health, plan one or two workouts, log meals and water, and check Coach after activity. WeekFit gets more useful as your data builds."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "В первые дни подключите Health, запланируйте одну-две тренировки, записывайте еду и воду и проверяйте Coach после активности. WeekFit становится полезнее по мере накопления данных."
          }
        }
      }
    },
    "support.guides.item25.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Start simple"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Начните просто"
          }
        }
      }
    },
    "support.guides.subtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A few simple ways to use WeekFit better."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Несколько простых способов использовать WeekFit лучше."
          }
        }
      }
    },
