    "highlights.story.trainingBackSeat.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "And it was likely the right call. Your recovery baselines dropped early in the cycle, and you naturally scaled back your activity volume to prevent burnout and protect your body."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "И, вероятно, это было правильным решением. Базовые показатели восстановления снизились в начале цикла, и вы естественно уменьшили активность, чтобы избежать перегруза и защитить тело."
          }
        }
      }
    },
