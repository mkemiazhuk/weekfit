        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Coaching insights, nutrition suggestions, recovery guidance, reminders, activity status, and metric summaries are not a substitute for advice from a doctor, dietitian, physiotherapist, or other qualified professional."
          }
        },
        "ru" : {
          "stringUnit" : {
