    "termsPrivacy.legal.about.p1" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WeekFit is a personal training, recovery, nutrition, hydration, sleep, and routine planning app."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WeekFit — приложение для личного планирования тренировок, восстановления, питания, гидратации, сна и повседневных рутин."
          }
        }
      }
    },
    "termsPrivacy.legal.about.p2" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The app helps you organize your day, review health-related metrics, and receive coaching-style suggestions before, during, and after workouts."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Приложение помогает организовать день, просматривать связанные со здоровьем метрики и получать рекомендации в стиле коучинга до, во время и после тренировок."
          }
        }
      }
    },
    "termsPrivacy.legal.about.p3" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WeekFit is intended for personal wellness, fitness planning, habit tracking, and lifestyle support. It is not intended for emergency use or clinical decision-making."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WeekFit предназначен для личного благополучия, фитнес-планирования, отслеживания привычек и поддержки образа жизни. Он не предназначен для экстренных ситуаций или клинических решений."
          }
        }
      }
    },
    "termsPrivacy.legal.about.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "About WeekFit"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "О WeekFit"
          }
        }
      }
    },
    "termsPrivacy.legal.appleHealthData.p1" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WeekFit may use data from Apple Health, Apple Watch, iPhone sensors, and information you enter manually inside the app."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WeekFit может использовать данные из Apple Health, Apple Watch, датчиков iPhone и информацию, которую вы вручную вводите в приложении."
          }
        }
      }
    },
    "termsPrivacy.legal.appleHealthData.p2" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This may include activity, workouts, sleep, energy, hydration, nutrition, body metrics, recovery-related signals, and other wellness data depending on the permissions you grant."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Это может включать активность, тренировки, сон, энергию, гидратацию, питание, параметры тела, сигналы восстановления и другие wellness-данные в зависимости от выданных разрешений."
          }
        }
      }
    },
    "termsPrivacy.legal.appleHealthData.p3" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Some features may be limited, unavailable, or less accurate if Apple Health access is not granted, if Apple Watch is not used, or if the underlying data is missing, delayed, incomplete, or inaccurate."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Некоторые функции могут быть ограничены, недоступны или менее точны, если доступ к Apple Health не предоставлен, Apple Watch не используется или исходные данные отсутствуют, задерживаются, неполные или неточные."
          }
        }
      }
    },
    "termsPrivacy.legal.appleHealthData.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apple Health & Device Data"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Данные Apple Health и устройств"
          }
        }
      }
    },
    "termsPrivacy.legal.appleHealthPermissions.p1" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WeekFit only accesses Apple Health categories that you explicitly allow through Apple Health permissions."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WeekFit получает доступ только к тем категориям Apple Health, которые вы явно разрешили в настройках Apple Health."
          }
        }
      }
    },
    "termsPrivacy.legal.appleHealthPermissions.p2" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You can review, modify, or revoke Apple Health permissions at any time in the Apple Health app or iOS Settings."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы можете просмотреть, изменить или отозвать разрешения Apple Health в любое время в приложении Apple Health или настройках iOS."
          }
        }
      }
    },
    "termsPrivacy.legal.appleHealthPermissions.p3" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If permissions are removed, WeekFit may no longer be able to update related metrics, sync completed workouts, personalize Coach suggestions, or show certain insights."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Если разрешения удалены, WeekFit может больше не обновлять связанные метрики, синхронизировать завершенные тренировки, персонализировать советы Coach или показывать отдельные инсайты."
          }
        }
      }
    },
    "termsPrivacy.legal.appleHealthPermissions.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apple Health Permissions"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Разрешения Apple Health"
          }
        }
      }
    },
    "termsPrivacy.legal.dataUse.p1" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WeekFit uses available activity, workout, nutrition, hydration, sleep, recovery, body, and planner data to provide app functionality and personalize your experience."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WeekFit использует доступные данные активности, тренировок, питания, гидратации, сна, восстановления, тела и планирования, чтобы обеспечивать функции приложения и персонализировать опыт."
          }
        }
      }
    },
    "termsPrivacy.legal.dataUse.p2" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This data may be used to show metrics, update Plan statuses, import completed workouts, calculate daily context, generate Coach suggestions, support reminders, and help you understand your routine."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Эти данные могут использоваться для отображения метрик, обновления статусов плана, импорта завершенных тренировок, расчета дневного контекста, генерации подсказок Coach, поддержки напоминаний и помощи в понимании вашей рутины."
          }
        }
      }
    },
    "termsPrivacy.legal.dataUse.p3" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The accuracy of insights depends on the accuracy, completeness, and timing of the data available to WeekFit."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Точность инсайтов зависит от точности, полноты и своевременности данных, доступных WeekFit."
          }
        }
      }
    },
    "termsPrivacy.legal.dataUse.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "How WeekFit Uses Data"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Как WeekFit использует данные"
          }
        }
      }
    },
    "termsPrivacy.legal.disclaimer.p1" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WeekFit provides general wellness, fitness, recovery, hydration, sleep, and nutrition information for educational and informational purposes only."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WeekFit предоставляет общую информацию о благополучии, фитнесе, восстановлении, гидратации, сне и питании только в образовательных и информационных целях."
          }
        }
      }
    },
    "termsPrivacy.legal.disclaimer.p2" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WeekFit does not provide medical advice, diagnosis, treatment, prescription, therapy, or professional healthcare services."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WeekFit не предоставляет медицинские советы, диагнозы, лечение, рецепты, терапию или профессиональные медицинские услуги."
          }
        }
      }
    },
    "termsPrivacy.legal.disclaimer.p3" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Coaching insights, nutrition suggestions, recovery guidance, reminders, activity status, and metric summaries are not a substitute for advice from a doctor, dietitian, physiotherapist, or other qualified professional."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Коучинговые инсайты, рекомендации по питанию, советы по восстановлению, напоминания, статусы активности и сводки метрик не заменяют консультацию врача, диетолога, физиотерапевта или другого квалифицированного специалиста."
          }
        }
      }
    },
    "termsPrivacy.legal.disclaimer.p4" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Always consult a qualified healthcare professional before making health-related decisions, starting a new training program, changing your diet, or relying on app-based guidance if you have any medical condition, injury, pregnancy, medication use, or other health concern."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Всегда консультируйтесь с квалифицированным медицинским специалистом перед решениями, связанными со здоровьем, началом новой программы тренировок, изменением питания или использованием рекомендаций приложения, если у вас есть заболевание, травма, беременность, прием лекарств или другие вопросы по здоровью."
          }
        }
      }
    },
    "termsPrivacy.legal.disclaimer.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Health, Fitness & Nutrition Disclaimer"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Отказ от ответственности по здоровью, фитнесу и питанию"
          }
        }
      }
    },
    "termsPrivacy.legal.notifications.p1" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WeekFit may send reminders for planned activities, meals, hydration, recovery routines, completion check-ins, or other app-related actions if you enable notifications."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WeekFit может отправлять напоминания о запланированных активностях, приемах пищи, гидратации, восстановительных рутинах, проверках завершения или других действиях в приложении, если вы включите уведомления."
          }
        }
      }
    },
    "termsPrivacy.legal.notifications.p2" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Notifications are optional and can be changed in WeekFit settings or iOS Settings."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Уведомления необязательны, их можно изменить в настройках WeekFit или iOS."
          }
        }
      }
    },
    "termsPrivacy.legal.notifications.p3" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reminder timing may be affected by device settings, Focus modes, notification permissions, and system limitations."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Время напоминаний может зависеть от настроек устройства, режимов Фокусирования, разрешений уведомлений и системных ограничений."
          }
        }
      }
    },
    "termsPrivacy.legal.notifications.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Notifications & Reminders"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Уведомления и напоминания"
          }
        }
      }
    },
    "termsPrivacy.legal.privacy.p1" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your health and wellness information remains under your control."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Информация о вашем здоровье и благополучии остается под вашим контролем."
          }
        }
      }
    },
    "termsPrivacy.legal.privacy.p2" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WeekFit does not sell personal health information and does not share Apple Health data with advertisers or data brokers."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WeekFit не продает персональную медицинскую информацию и не передает данные Apple Health рекламодателям или брокерам данных."
          }
        }
      }
    },
    "termsPrivacy.legal.privacy.p3" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Where possible, data processing is performed on device to reduce unnecessary data transfer and collection."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "По возможности обработка данных выполняется на устройстве, чтобы уменьшить ненужную передачу и сбор данных."
          }
        }
      }
    },
    "termsPrivacy.legal.privacy.p4" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If future features require external processing, account services, cloud sync, analytics, or support diagnostics, those features should be disclosed separately and handled according to the app privacy policy and applicable App Store requirements."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
