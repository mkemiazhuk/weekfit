    "support.guides.item25.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "For the first few days, connect Health, plan one or two workouts, log meals and water, and check Coach after activity. WeekFit gets more useful as your data builds."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "В первые дни подключите Здоровье, запланируйте одну-две тренировки, записывайте еду и воду и проверяйте Тренера после активности. WeekFit становится полезнее по мере накопления данных."
          }
        }
      }
    },
