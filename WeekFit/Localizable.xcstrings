    "today.aiCoach.steadyBalanced" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Timeline rhythm looks flawless. Macronutrients, movement, and recovery structures are perfectly balanced."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ритм таймлайна выглядит отлично. Макроэлементы, движение и восстановление сбалансированы."
          }
        }
      }
    },
    "today.aiCoach.steadyUnderFueled" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Flawless rhythm, but you are under-fueled for today's metabolic demand. Prioritize a dense protein-fat block before window closure."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ритм отличный, но энергии мало для сегодняшней нагрузки. Добавьте плотный белково-жировой прием пищи до конца окна."
          }
        }
      }
    },
    "today.aiCoach.walkActiveFormat" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cruising through your %@. Perfect opportunity to downregulate central nervous system fatigue and steady your cardiovascular matrix."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы спокойно проходите %@. Хороший момент снизить усталость нервной системы и стабилизировать сердечно-сосудистую нагрузку."
          }
        }
      }
    },
    "today.aiCoach.walkHighExpenditureFormat" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Current state: Ultra-high energy expenditure today (%lld kcal). Keep this walk strictly low-intensity. DO NOT spike your heart rate; focus on active neural drainage."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Текущее состояние: сегодня очень высокий расход энергии (%lld ккал). Держите прогулку строго низкоинтенсивной. Не поднимайте пульс; сфокусируйтесь на активном восстановлении."
          }
        }
      }
    },
    "today.aiCoach.walkLowWaterFormat" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Analyzing your day: You have only %@L of water logged with %lld workouts done. Low-intensity volume will increase vascular dehydration. DO NOT wait until evening — log 350ml right now."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Анализ дня: записано только %@ л воды при %lld выполненных тренировках. Низкоинтенсивный объем усилит обезвоживание. Не ждите вечера — запишите 350 мл сейчас."
          }
        }
      }
    },
    "today.aiCoach.workoutActiveFormat" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Push through %@. Focus on intra-session pacing. Post-workout glycogen re-feed protocols are already staging."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Продолжайте %@. Фокус на темпе внутри сессии. Восстановительное питание после тренировки уже готовится."
          }
        }
      }
    },
