    "coach.section.heatWhy.text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Heat can help circulation, muscle relaxation and the transition into recovery mode. Hydration afterwards is what turns the session into recovery support rather than extra stress."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Тепло может поддержать кровообращение, расслабление мышц и переход в восстановление. Вода после сессии превращает ее в поддержку, а не в дополнительный стресс."
          }
        }
      }
    },
    "coach.section.hydrationSupport.title" : {
      "extractionState" : "manual",
      "localizations" : {
