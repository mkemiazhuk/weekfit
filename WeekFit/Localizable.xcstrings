    "highlights.story.activityUpRecoveryDown.bodyFormat" : {
      "comment" : "Monthly highlight body. The argument is the activity increase percentage.",
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your training volume increased by %lld%%, but your recovery metrics didn't match the output. Your body is running on a temporary deficit, causing your overall readiness to trend downward."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Объем тренировок вырос на %lld%%, но метрики восстановления не успели за нагрузкой. Тело временно работает в дефиците, поэтому общая готовность снижается."
          }
        }
      }
    },
    "highlights.story.activityUpRecoveryDown.headline" : {
      "extractionState" : "manual",
